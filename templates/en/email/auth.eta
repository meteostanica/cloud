<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body {
            margin: 0;
            display: flex;
            flex-direction: column;
            padding-inline: 10%;
            font-family: sans-serif;
            line-height: 1.3;
            background-color: #eee;
            gap: 0.5em;
        }

        h2, p {
            margin-block: 0.5em;
        }

        [role="button"] {
            background-color: rgba(0, 0, 0, 0.1);
            border-radius: 0.5em;
            padding: 0.5em 1em;
            text-decoration: none;
            color: initial;
            border: none;
            width: max-content;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5em;
            font-size: 1em;
            height: max-content;
        }

        [role="button"].primary {
            color: #eee;
            background-color: rgb(50, 50, 255);
        }
    </style>
</head>
<body>
    <h2>meteostanica</h2>

    <p>hi,</p>

    <p>to login click on the button below.</p>

    <a role="button" class="primary" href="<%= it.link %>">click here</a>

    <p>or enter this code: <strong><%= it.code %></strong></p>


    <p>cannot click on the link? copy it: <%= it.link %></p>

    <footer>
        <p><small>if you did not request this email, you can safely ignore it.</small></p>
        <p><small>meteostanica <%= new Date().getFullYear() %></small></p>
    </footer>
</body>
</html>